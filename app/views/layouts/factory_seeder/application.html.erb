<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FactorySeeder - Database Seeding Made Easy</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- FactorySeeder CSS -->
    <style>
      <%= raw FactorySeeder::AssetHelper.css_content('factory_seeder.css') %>
    </style>
  </head>
  <body>
    <header class="app-header">
      <div>
        <div class="app-header__title">FACTORY / SEEDER by Wecasa</div>
        <div class="app-header__tagline">Industrial-quality seeds powered by FactoryBot</div>
      </div>
      <%= link_to "Dashboard", root_path, class: "app-header__link" %>
    </header>
    <%= yield %>

    <script>
      (function () {
        document.addEventListener('submit', function (event) {
          var form = event.target;
          if (!form || form.tagName !== 'FORM') return;

          var submitButton = form.querySelector('input[type=submit], button[type=submit]');
          if (!submitButton) return;

          if (submitButton.dataset.fsRunning === 'true') {
            event.preventDefault();
            return;
          }

          submitButton.dataset.fsRunning = 'true';
          var runningLabel = submitButton.getAttribute('data-running-label') || 'Running…';

          if (submitButton.tagName === 'INPUT') {
            submitButton.dataset.fsOriginalLabel = submitButton.value;
            submitButton.value = runningLabel;
          } else {
            submitButton.dataset.fsOriginalLabel = submitButton.textContent;
            submitButton.textContent = runningLabel;
          }

          submitButton.disabled = true;
          submitButton.classList.add('btn--running');
        });
      })();
    </script>
  </body>
</html>